{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Correlation: Japanese Anime vs. Manga Interest",
    "subtitle": "Hover over points to highlight specific states",
    "anchor": "start"
  },
  "width": 500,
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/lzho0085/FIT2179/refs/heads/main/geoMap_clean_en.csv"
  },
  "layer": [
    {
      "params": [{
        "name": "hover",
        "select": {"type": "point", "on": "mouseover", "clear": "mouseout"}
      }],
      "mark": {
        "type": "point", 
        "filled": true, 
        "stroke": "white", 
        "strokeWidth": 1
      },
      "encoding": {
        "x": {
          "field": "Japanese Anime",
          "type": "quantitative",
          "title": "Anime Interest Score",
          "scale": {"zero": false}
        },
        "y": {
          "field": "Japanese Manga",
          "type": "quantitative",
          "title": "Manga Interest Score",
          "scale": {"zero": false}
        },
        "color": {
          "condition": {"param": "hover", "empty": false, "value": "#e67e22"},
          "value": "#3498db"
        },
        "size": {
          "condition": {"param": "hover", "empty": false, "value": 300},
          "value": 120
        },
        "opacity": {
          "condition": {"param": "hover", "empty": false, "value": 1},
          "value": 0.6
        },
        "tooltip": [
          {"field": "State", "type": "nominal", "title": "State"},
          {"field": "Japanese Anime", "type": "quantitative", "title": "Anime Score"},
          {"field": "Japanese Manga", "type": "quantitative", "title": "Manga Score"}
        ]
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#d62728",
        "size": 2,
        "strokeDash": [5, 5]
      },
      "transform": [
        {
          "regression": "Japanese Manga",
          "on": "Japanese Anime"
        }
      ],
      "encoding": {
        "x": {"field": "Japanese Anime", "type": "quantitative"},
        "y": {"field": "Japanese Manga", "type": "quantitative"}
      }
    },
    {
      "transform": [
        {"filter": "datum['Japanese Manga'] >= 19"}
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 12,
        "dy": 4,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#2c3e50"
      },
      "encoding": {
        "x": {"field": "Japanese Anime", "type": "quantitative"},
        "y": {"field": "Japanese Manga", "type": "quantitative"},
        "text": {"field": "State"}
      }
    }
  ],
  "config": {
    "axis": {"grid": true, "gridDash": [3,3]}
  }
}
