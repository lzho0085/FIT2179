{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Top Motivations for Learning Japanese",
    "subtitle": "Analysis of learners outside regular school systems",
    "anchor": "start"
  },
  "width": 350,
  "height": 350,
  "data": {
    "url": "https://raw.githubusercontent.com/lzho0085/2179/main/japanese_learning_objectives.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "arc", 
        "innerRadius": 70, 
        "stroke": "#ffffff",
        "strokeWidth": 1.5,
        "cornerRadius": 4,
        "padAngle": 0.015
      },
      "encoding": {
        "theta": {"field": "Percentage", "type": "quantitative"},
        "radius": {
          "field": "Percentage",
          "type": "quantitative",
          "scale": {"type": "sqrt", "zero": true, "range": [70, 160]}
        },
        "color": {
          "field": "Objective",
          "type": "nominal",
          "scale": {
            "range": [
              "#1E50A2", "#F8C300", "#FEDFE1", "#745399", "#58B2DC", 
              "#D0104C", "#DCD3B2", "#66327C", "#A8D8B9", "#F596AA", 
              "#8F77B5", "#B5CAA0", "#E87A90", "#9EA1A3"
            ]
          },
          "legend": {
            "orient": "bottom",
            "columns": 2,
            "title": "Motivations", 
            "labelLimit": 400
          }
        },
        "tooltip": [
          {"field": "Objective", "title": "Motive"},
          {"field": "Percentage", "title": "Percentage (%)"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "radius": 0,
        "fontSize": 14,
        "fontWeight": "bold",
        "color": "#333333",
        "text": ["Learning", "Drivers"],
        "align": "center"
      }
    }
  ],
  "config": {
    "view": {"stroke": null}
  }
}