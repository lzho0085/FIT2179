{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Top Motivations for Learning Japanese",
    "subtitle": "Analysis of learners outside regular school systems",
    "anchor": "start"
  },
  "width": 350,
  "height": 350,
  "data": {
    "url": "https://raw.githubusercontent.com/lzho0085/2179/main/japanese_learning_objectives.csv"
  },
  "transform": [
    {
      "filter": "datum.Percentage >= 4"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "arc", 
        "innerRadius": 85,
        "outerRadius": 140,
        "stroke": "#ffffff",
        "strokeWidth": 2.5,
        "cornerRadius": 4,
        "padAngle": 0.02
      },
      "encoding": {
        "theta": {"field": "Percentage", "type": "quantitative"},
        "color": {
          "field": "Objective",
          "type": "nominal",
          "scale": {
            "range": [
              "#1E50A2", "#F8C300", "#D0104C", "#58B2DC", "#745399", 
              "#A8D8B9", "#E87A90", "#8F77B5", "#B5CAA0", "#F596AA", "#9EA1A3"
            ]
          },
          "legend": {
            "orient": "bottom",
            "columns": 2,
            "title": "Core Motivations", 
            "labelLimit": 400
          }
        },
        "tooltip": [
          {"field": "Objective", "title": "Motive"},
          {"field": "Percentage", "title": "Percentage (%)"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "radius": 0,
        "fontSize": 15,
        "fontWeight": "bold",
        "color": "#333333",
        "text": ["Learning", "Drivers"],
        "align": "center"
      }
    }
  ],
  "config": {
    "view": {"stroke": null}
  }
}