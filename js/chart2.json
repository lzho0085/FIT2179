{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Japanese Learners in SE Asia",
  "width": 300,
  "height": 300,
  "data": {
    "url": "https://raw.githubusercontent.com/lzho0085/2179/refs/heads/main/southeast_asia_japanese_learners.csv"
  },
  "mark": {
    "type": "circle",
    "opacity": 0.7,
    "stroke": "black",
    "strokeWidth": 0.5
  },
  "encoding": {
    "x": {
      "field": "Institutions",
      "type": "quantitative",
      "scale": {
        "type": "log"
      }
    },
    "y": {
      "field": "Teachers",
      "type": "quantitative",
      "scale": {
        "type": "log"
      }
    },
    "size": {
      "field": "Learners",
      "type": "quantitative",
      "scale": {
        "range": [
          100,
          1500
        ]
      }
    },
    "color": {
      "field": "Country",
      "type": "nominal",
      "scale": {
        "range": [
          "#332288",
          "#117733",
          "#44AA99",
          "#88CCEE",
          "#DDCC77",
          "#CC6677",
          "#AA4499"
        ]
      }
    },
    "tooltip": [
      {
        "field": "Country"
      },
      {
        "field": "Learners",
        "format": ","
      }
    ]
  }
}