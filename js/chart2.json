{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Japanese Learners in SE Asia",
  "width": 300,
  "height": 300,
  "data": {
    "url": "https://raw.githubusercontent.com/lzho0085/2179/refs/heads/main/southeast_asia_japanese_learners.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "circle",
        "opacity": 0.7,
        "stroke": "black",
        "strokeWidth": 0.5
      },
      "encoding": {
        "x": {
          "field": "Institutions",
          "type": "quantitative",
          "scale": {"zero": true},
          "title": "Number of Institutions"
        },
        "y": {
          "field": "Teachers",
          "type": "quantitative",
          "scale": {"zero": true},
          "title": "Number of Teachers"
        },
        "size": {
          "field": "Learners",
          "type": "quantitative",
          "scale": {
            "range": [100, 1500]
          },
          "legend": {"title": "Learners"}
        },
        "color": {
          "field": "Country",
          "type": "nominal",
          "scale": {
            "range": [
              "#332288",
              "#117733",
              "#44AA99",
              "#88CCEE",
              "#DDCC77",
              "#CC6677",
              "#AA4499"
            ]
          }
        },
        "tooltip": [
          {"field": "Country", "type": "nominal"},
          {"field": "Learners", "type": "quantitative", "format": ","},
          {"field": "Institutions", "type": "quantitative", "format": ","},
          {"field": "Teachers", "type": "quantitative", "format": ","}
        ]
      }
    },
    {
      "transform": [
        {"filter": "datum.Country == 'Indonesia'"}
      ],
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -30,
        "dy": 0,
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#332288"
      },
      "encoding": {
        "x": {"field": "Institutions", "type": "quantitative"},
        "y": {"field": "Teachers", "type": "quantitative"},
        "text": {"value": "Highest demand in SE Asia"}
      }
    }
  ]
}