{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Anime Search Interest by State in Malaysia",
    "subtitle": "Regional heatmap of Japanese anime popularity (2025-2026)",
    "anchor": "start"
  },
  "width": 800,
  "height": 450,
  "params": [
    {
      "name": "zoom_level",
      "value": 2800,
      "bind": {
        "input": "range",
        "min": 1000,
        "max": 8000,
        "step": 100,
        "name": "Map Zoom: "
      }
    },
    {
      "name": "center_x",
      "value": 109,
      "bind": {
        "input": "range",
        "min": 95,
        "max": 125,
        "step": 1,
        "name": "Center Longitude (X): "
      }
    },
    {
      "name": "center_y",
      "value": 4.5,
      "bind": {
        "input": "range",
        "min": 0,
        "max": 10,
        "step": 0.5,
        "name": "Center Latitude (Y): "
      }
    }
  ],
  "projection": {
    "type": "mercator",
    "scale": {"expr": "zoom_level"},
    "center": {"expr": "[center_x, center_y]"}
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/lzho0085/2179/main/mys_state.json",
        "format": {"type": "topojson", "feature": "mys_admbnda_adm1_unhcr_20210211"}
      },
      "transform": [
        {
          "calculate": "upper(datum.properties.ADM1_EN)",
          "as": "state_upper"
        },
        {
          "lookup": "state_upper",
          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/lzho0085/2179/refs/heads/main/geoMap_clean_en.csv"
            },
            "key": "State",
            "fields": ["Japanese Anime"]
          }
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 0.8
      },
      "encoding": {
        "color": {
          "field": "Japanese Anime",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [26, 29, 32],
            "scheme": "oranges"
          },
          "title": "Search Index",
          "legend": {
            "orient": "bottom-right",
            "direction": "horizontal"
          }
        },
        "tooltip": [
          {"field": "properties.ADM1_EN", "type": "nominal", "title": "State"},
          {"field": "Japanese Anime", "type": "quantitative", "title": "Anime Interest Score"}
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": "transparent"}
  }
}