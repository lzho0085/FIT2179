{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Cultural Preference Breakdown by State",
  "width": 300,
  "height": 300,
  "data": {
    "url": "https://raw.githubusercontent.com/lzho0085/FIT2179/main/geoMap_clean_en.csv"
  },
  "transform": [
    {
      "fold": ["Japanese Anime", "Japanese Manga", "Japanese Cuisine"],
      "as": ["Category", "Value"]
    }
  ],
  "mark": "bar",
  "encoding": {
    "y": {"field": "State", "type": "nominal", "title": null},
    "x": {"field": "Value", "type": "quantitative", "stack": "normalize", "axis": {"format": "%"}},
    "color": {
      "field": "Category", 
      "type": "nominal",
      "scale": {
        "domain": ["Japanese Anime", "Japanese Manga", "Japanese Cuisine"],
        "range": ["#D55E00", "#0072B2", "#E69F00"]
      }
    },
    "tooltip": [
      {"field": "State"}, 
      {"field": "Category"}, 
      {"field": "Value", "format": ".2f"}
    ]
  }
}
