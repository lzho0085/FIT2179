{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Heatmap: Cultural Interest Intensity by State",
    "subtitle": "Darker colors indicate higher search interest",
    "anchor": "start"
  },
  "width": 300,
  "height": 450,
  "data": {
    "url": "https://raw.githubusercontent.com/lzho0085/FIT2179/refs/heads/main/geoMap_clean_en.csv"
  },
  "transform": [
    {
      "fold": ["Japanese Anime", "Japanese Manga", "Japanese Cuisine"],
      "as": ["Category", "Score"]
    }
  ],
  "mark": "rect",
  "encoding": {
    "y": {
      "field": "State",
      "type": "nominal",
      "title": null,
      "sort": "-x"
    },
    "x": {
      "field": "Category",
      "type": "nominal",
      "title": null,
      "axis": {"labelAngle": 0}
    },
    "color": {
      "field": "Score",
      "type": "quantitative",
      "scale": {"scheme": "purples"},
      "title": "Interest Score"
    },
    "tooltip": [
      {"field": "State", "type": "nominal"},
      {"field": "Category", "type": "nominal"},
      {"field": "Score", "type": "quantitative", "title": "Score"}
    ]
  },
  "config": {
    "view": {"stroke": "transparent"},
    "axis": {"domain": false, "ticks": false}
  }
}
