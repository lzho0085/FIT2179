{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Rising Food Searches",
  "width": 300,
  "height": 350,
  "data": {
    "url": "https://raw.githubusercontent.com/lzho0085/2179/main/searched_with_rising-queries_MY_20250506-1735_20260506-1735.csv"
  },
  "transform": [
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "search interest", "order": "descending"}]
    },
    {
      "filter": "datum.rank <= 10"
    },
    {
      "calculate": "upper(substring(datum.query, 0, 1)) + substring(datum.query, 1)", 
      "as": "FormattedQuery"
    }
  ],
  "mark": {"type": "bar", "cornerRadiusEnd": 4},
  "encoding": {
    "y": {
      "field": "FormattedQuery", 
      "type": "nominal", 
      "sort": "-x", 
      "title": null,
      "axis": {"labelFontSize": 12}
    },
    "x": {
      "field": "search interest", 
      "type": "quantitative",
      "title": "Search Interest"
    },
    "color": {"value": "#E69F00"},
    "tooltip": [
      {"field": "FormattedQuery", "title": "Search Query"},
      {"field": "increase percent", "title": "Increase (%)"}
    ]
  }
}