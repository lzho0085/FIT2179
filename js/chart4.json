{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "The Cultural Waves: Anime vs Manga vs Cuisine",
  "width": 700,
  "height": 250,
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/lzho0085/FIT2179/main/time_series_clean_en.csv"
      },
      "transform": [
        {
          "fold": ["Japanese Anime", "Japanese Manga", "Japanese Cuisine"],
          "as": ["Category", "Interest"]
        }
      ],
      "mark": "area",
      "encoding": {
        "x": {
          "field": "Time",
          "type": "temporal",
          "axis": {"grid": false}
        },
        "y": {
          "field": "Interest",
          "type": "quantitative",
          "stack": "center",
          "axis": null
        },
        "color": {
          "field": "Category",
          "type": "nominal",
          "scale": {
            "domain": ["Japanese Anime", "Japanese Manga", "Japanese Cuisine"],
            "range": ["#D55E00", "#0072B2", "#E69F00"]
          }
        },
        "tooltip": [
          {"field": "Time", "type": "temporal", "title": "Date"},
          {"field": "Category", "title": "Category"},
          {"field": "Interest", "title": "Search Index"}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"Time": "2026-03-22", "text": "Spring Anime Season Surge"}
        ]
      },
      "layer": [
        {
          "mark": {
            "type": "rule", 
            "color": "#2c3e50", 
            "strokeDash": [4, 4], 
            "size": 1.5
          },
          "encoding": {
            "x": {"field": "Time", "type": "temporal"}
          }
        },
        {
          "mark": {
            "type": "text",
            "align": "right",
            "dx": -8,
            "y": 15,
            "fontSize": 12,
            "fontWeight": "bold",
            "color": "#2c3e50"
          },
          "encoding": {
            "x": {"field": "Time", "type": "temporal"},
            "text": {"field": "text", "type": "nominal"}
          }
        }
      ]
    }
  ]
}
