{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {"url": "https://raw.githubusercontent.com/lzho0085/2179/main/time_series_clean_en.csv"},
  "vconcat": [
    {
      "width": 700, "height": 250,
      "title": "Interactive Search Trends",
      "mark": "line",
      "encoding": {
        "x": {"field": "Time", "type": "temporal", "scale": {"domain": {"param": "brush"}}, "axis": {"title": ""}},
        "y": {"field": "Japanese Anime", "type": "quantitative", "title": "Search Interest"},
        "color": {"value": "#D55E00"} 
      }
    },
    {
      "width": 700, "height": 60,
      "mark": "area",
      "params": [{"name": "brush", "select": {"type": "interval", "encodings": ["x"]}}],
      "encoding": {
        "x": {"field": "Time", "type": "temporal", "title": "Drag to select time period"},
        "y": {"field": "Japanese Anime", "type": "quantitative", "axis": false},
        "color": {"value": "#D55E00"}
      }
    }
  ]
}